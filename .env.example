# ============================================================
# PARAMETRES COMMUNS
# ============================================================
SECRET_KEY=remplacez-par-une-cle-longue-et-secrete
DEBUG=True
TIME_ZONE=Africa/Sao_Tome
GPS_API_KEY=mototrack-gps-cle-a-modifier
GPS_ALERT_DELAY_MINUTES=10
RESPONSABLE_REGISTRATION_CODE=remplacez-par-un-code-secret
# Optionnel : active Google Maps sur les cartes web.
# Sans cette clé, MotoTrack utilise automatiquement Leaflet + Esri.
MAP_PROVIDER=esri
GOOGLE_MAPS_API_KEY=
# Pour Google Maps :
# MAP_PROVIDER=google
# GOOGLE_MAPS_API_KEY=votre-cle-google-maps
ALLOWED_HOSTS=127.0.0.1,localhost,172.16.101.181
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://172.16.101.181:8000

# ============================================================
# MODE LOCAL - PostgreSQL installé sur l'ordinateur
# Laissez DATABASE_URL non définie dans ce mode.
# ============================================================
DB_ENGINE=postgresql
DB_NAME=mototrack
DB_USER=mototrack_user
DB_PASSWORD=mot_de_passe_local
DB_HOST=localhost
DB_PORT=5432
DB_SSL_REQUIRE=False

# Pour un test rapide sans PostgreSQL uniquement :
# DB_ENGINE=sqlite

# ============================================================
# MODE PRODUCTION - Supabase PostgreSQL + Render
# Sur Render, créez DATABASE_URL avec l'URI fournie par Supabase.
# Commentez les variables DB_* locales ou laissez DATABASE_URL prioritaire.
# ============================================================
# DEBUG=False
# SECRET_KEY=generez-une-longue-cle-aleatoire
# GPS_API_KEY=generez-une-cle-secrete-pour-les-esp32
# RESPONSABLE_REGISTRATION_CODE=generez-un-code-prive
# DATABASE_URL=postgresql://postgres.PROJECT_REF:MOT_DE_PASSE@aws-0-REGION.pooler.supabase.com:6543/postgres
# DB_SSL_REQUIRE=True
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# ALLOWED_HOSTS=mototrack.onrender.com
# CSRF_TRUSTED_ORIGINS=https://mototrack.onrender.com
# MAP_PROVIDER=esri
